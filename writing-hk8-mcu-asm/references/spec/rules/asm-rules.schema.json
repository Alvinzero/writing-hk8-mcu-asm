{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://internal.example/spec/hk64s8x/asm-rules.schema.json",
  "title": "HK64S825 ASM Corporate Rules",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "rule_set_id",
    "rule_set_version",
    "generated_at",
    "language",
    "chip_family",
    "validated_chip_model",
    "normative_levels",
    "severity",
    "toolchain_ids",
    "evidence_levels",
    "rules"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "rule_set_id": {
      "const": "HK64S825-ASM-CORPORATE"
    },
    "rule_set_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "language": {
      "type": "string"
    },
    "chip_family": {
      "type": "string"
    },
    "validated_chip_model": {
      "type": "string"
    },
    "normative_levels": {
      "type": "object"
    },
    "severity": {
      "type": "object"
    },
    "toolchain_ids": {
      "type": "object"
    },
    "evidence_levels": {
      "type": "object"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "source",
        "note"
      ],
      "properties": {
        "level": {
          "enum": [
            "E1",
            "E2",
            "E3",
            "E4",
            "E5",
            "E6",
            "OPEN"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "normative_level",
        "severity",
        "status",
        "scope",
        "requirement",
        "rationale",
        "bad_example",
        "good_example",
        "verification",
        "evidence",
        "confidence",
        "toolchain_applicability",
        "tags"
      ],
      "properties": {
        "rule_id": {
          "type": "string",
          "pattern": "^HK-[A-Z0-9-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 2
        },
        "normative_level": {
          "enum": [
            "MUST",
            "SHOULD",
            "MAY"
          ]
        },
        "severity": {
          "enum": [
            "BLOCKER",
            "ERROR",
            "WARNING",
            "INFO"
          ]
        },
        "status": {
          "enum": [
            "active",
            "restricted",
            "deprecated",
            "open"
          ]
        },
        "scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "requirement": {
          "type": "string",
          "minLength": 5
        },
        "rationale": {
          "type": "string",
          "minLength": 5
        },
        "bad_example": {
          "type": "string"
        },
        "good_example": {
          "type": "string"
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low",
            "open"
          ]
        },
        "toolchain_applicability": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "company_ide",
              "python_source_module_cli",
              "simulator",
              "hardware"
            ]
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
