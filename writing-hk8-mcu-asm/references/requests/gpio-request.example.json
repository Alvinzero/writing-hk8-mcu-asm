{
  "schema_version": 1,
  "chip": "HK64S825",
  "behavior": "Drive one confirmed GPIO as a measurable heartbeat output.",
  "clock": {
    "osc_hz": 16000000,
    "sck_ps": "reset"
  },
  "pins": {
    "led_outputs": {
      "port": "PA",
      "bits": [
        0
      ],
      "direction": "output",
      "drive": "push_pull",
      "active_level": "high",
      "initial_state": "off",
      "preserve_unowned_bits": true
    }
  },
  "peripherals": [
    {
      "name": "gpio"
    }
  ],
  "timing": {
    "precision": "precise",
    "delay_targets": [
      {
        "label": "DELAY_500MS",
        "target_us": 500000,
        "tolerance_percent": 1.0
      }
    ]
  },
  "memory_limits": {
    "rom_bytes": 2048,
    "ram_bytes": 64
  },
  "board": {
    "id": "REPLACE_WITH_BOARD_ID"
  },
  "acceptance": [
    {
      "name": "heartbeat-output",
      "observable": "logic-analyzer gpio waveform",
      "expected": "1 kHz square wave within declared tolerance"
    }
  ],
  "allow_nonvolatile_changes": false
}
